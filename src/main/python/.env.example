# ============================================================================
# E-Commerce Analytics Platform - Environment Configuration
# ============================================================================
# Copy this file to .env and update values as needed
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   docker-compose up -d
# ============================================================================

# ============================================================================
# Kafka Configuration (Days 1-4)
# ============================================================================

# Kafka broker connection
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Schema Registry URL (Day 6)
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081

# Consumer group prefix
KAFKA_CONSUMER_GROUP_PREFIX=ecommerce-analytics

# ============================================================================
# PostgreSQL Configuration (Day 7: Analytics Database)
# ============================================================================

# Database connection
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ecommerce_analytics
POSTGRES_USER=analytics_user
POSTGRES_PASSWORD=analytics_pass

# Connection pool settings
POSTGRES_MAX_CONNECTIONS=20
POSTGRES_MIN_CONNECTIONS=2

# ============================================================================
# Kafka Connect Configuration (Day 7)
# ============================================================================

# Connect REST API
KAFKA_CONNECT_URL=http://localhost:8083

# JDBC connector settings
JDBC_CONNECTOR_MAX_TASKS=3
JDBC_CONNECTOR_BATCH_SIZE=1000

# ============================================================================
# Monitoring Configuration (Day 8)
# ============================================================================

# Prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_SCRAPE_INTERVAL=15s

# Grafana
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Metrics export
METRICS_ENABLED=true
METRICS_PORT=9091

# ============================================================================
# Application Configuration
# ============================================================================

# Application environment
APP_ENV=development
# Options: development, staging, production

# Logging
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Python path
PYTHONPATH=/app/src/main/python

# ============================================================================
# Producer Configuration (Day 3)
# ============================================================================

# Idempotence and reliability
PRODUCER_ENABLE_IDEMPOTENCE=true
PRODUCER_ACKS=all
PRODUCER_RETRIES=3

# Performance tuning
PRODUCER_COMPRESSION_TYPE=snappy
# Options: none, gzip, snappy, lz4, zstd

PRODUCER_LINGER_MS=10
PRODUCER_BATCH_SIZE=16384
PRODUCER_MAX_IN_FLIGHT=5

# ============================================================================
# Consumer Configuration (Day 4)
# ============================================================================

# Offset management
CONSUMER_AUTO_OFFSET_RESET=earliest
# Options: earliest, latest, none

CONSUMER_ENABLE_AUTO_COMMIT=false
CONSUMER_COMMIT_INTERVAL=10

# Performance
CONSUMER_MAX_POLL_RECORDS=500
CONSUMER_SESSION_TIMEOUT_MS=30000
CONSUMER_HEARTBEAT_INTERVAL_MS=3000

# ============================================================================
# Stream Processing Configuration (Day 6: Faust)
# ============================================================================

# Faust application settings
FAUST_BROKER=kafka://localhost:9092
FAUST_STORE_URI=rocksdb://data/rocksdb

# Processing guarantees
FAUST_PROCESSING_GUARANTEE=exactly_once
# Options: at_least_once, exactly_once

# Worker settings
FAUST_WORKER_LOGLEVEL=INFO
FAUST_NUM_WORKERS=1

# Windowing
FAUST_WINDOW_SIZE_MINUTES=5
FAUST_WINDOW_EXPIRES_HOURS=1

# ============================================================================
# Schema Registry Configuration (Day 6)
# ============================================================================

# Schema compatibility mode
SCHEMA_COMPATIBILITY_LEVEL=BACKWARD
# Options: NONE, BACKWARD, FORWARD, FULL, BACKWARD_TRANSITIVE, FORWARD_TRANSITIVE, FULL_TRANSITIVE

# Schema validation
SCHEMA_AUTO_REGISTER=true

# ============================================================================
# Error Handling Configuration (Day 8)
# ============================================================================

# Dead Letter Queue
DLQ_ENABLED=true
DLQ_TOPIC_PREFIX=dlq-
DLQ_MAX_RETRIES=3

# Error tracking
SENTRY_DSN=
# Set this for error tracking in production

# ============================================================================
# Demo Configuration
# ============================================================================

# Demo data generation
DEMO_NUM_EVENTS=100
DEMO_DELAY_SECONDS=0.5
DEMO_SEED=42

# Sample data
FAKER_LOCALE=en_US

# ============================================================================
# Airflow Configuration (Extensions)
# ============================================================================

# Airflow webserver
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=admin

# Fernet key for encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
AIRFLOW_FERNET_KEY=46BKJoQYlPPOexq0OhDZnIlNepKFf87WFwLbfzqDDho=

# Executor
AIRFLOW_EXECUTOR=CeleryExecutor
# Options: SequentialExecutor, LocalExecutor, CeleryExecutor, KubernetesExecutor

# DAG settings
AIRFLOW_LOAD_EXAMPLES=false
AIRFLOW_DAGS_ARE_PAUSED_AT_CREATION=true

# ============================================================================
# Security Configuration (Day 8 - Production)
# ============================================================================

# Enable SSL/TLS
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
# Options: PLAINTEXT, SSL, SASL_PLAINTEXT, SASL_SSL

# SASL configuration
KAFKA_SASL_MECHANISM=
# Options: PLAIN, SCRAM-SHA-256, SCRAM-SHA-512, GSSAPI

KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# SSL certificates (paths)
KAFKA_SSL_CA_LOCATION=
KAFKA_SSL_CERT_LOCATION=
KAFKA_SSL_KEY_LOCATION=
KAFKA_SSL_KEY_PASSWORD=

# ============================================================================
# Docker Configuration
# ============================================================================

# Build arguments
DOCKER_REGISTRY=
DOCKER_IMAGE_TAG=latest

# Resource limits
DOCKER_MEMORY_LIMIT=2g
DOCKER_CPU_LIMIT=2.0

# ============================================================================
# Development Configuration
# ============================================================================

# Debug mode
DEBUG=false

# Hot reload
DEV_RELOAD=false

# Test database
TEST_POSTGRES_DB=ecommerce_analytics_test

# ============================================================================
# Production Configuration
# ============================================================================

# High availability
KAFKA_REPLICATION_FACTOR=3
KAFKA_MIN_INSYNC_REPLICAS=2

# Data retention
KAFKA_RETENTION_MS=604800000
# Default: 7 days (604800000 ms)

# Partitions
KAFKA_NUM_PARTITIONS=12

# Connection pooling
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ============================================================================
# Backup Configuration
# ============================================================================

# Database backups
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
# Daily at 2 AM

BACKUP_RETENTION_DAYS=7

# ============================================================================
# Feature Flags
# ============================================================================

# Enable/disable features
FEATURE_FRAUD_DETECTION=true
FEATURE_REAL_TIME_ANALYTICS=true
FEATURE_RECOMMENDATIONS=false

# ============================================================================
# Third-party Integrations
# ============================================================================

# Slack notifications
SLACK_WEBHOOK_URL=

# Email alerts
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL=

# ============================================================================
# Notes:
# ============================================================================
# 1. Never commit the actual .env file to version control
# 2. Keep .env.example updated when adding new variables
# 3. Use strong passwords in production
# 4. Rotate credentials regularly
# 5. Use secrets management in production (e.g., Vault, AWS Secrets Manager)
# ============================================================================
